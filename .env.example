# ══════════════════════════════════════════════════════════════════════════════
# .env.example — Copy to .env.local and fill in your values
# NEVER commit .env or .env.local to git
# ══════════════════════════════════════════════════════════════════════════════

# ── LiveKit Cloud ────────────────────────────────────────────────────────────
LIVEKIT_URL=wss://your-livekit-url
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret
OUTBOUND_TRUNK_ID=ST_xxxxxxxxxxxx
SIP_TRUNK_ID=ST_xxxxxxxxxxxx

# ── OpenAI (LLM) ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
GEMINI_API_KEY=your_gemini_api_key

# ── Sarvam AI (STT + TTS) ────────────────────────────────────────────────────
SARVAM_API_KEY=your_sarvam_api_key

# ── Supabase (Database) ──────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ── Supabase S3 (Call Recordings) ────────────────────────────────────────────
SUPABASE_S3_ACCESS_KEY=your_s3_access_key
SUPABASE_S3_SECRET_KEY=your_s3_secret_key
SUPABASE_S3_ENDPOINT=https://your-project.storage.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=ap-south-1

# ── Cal.com (Booking) ────────────────────────────────────────────────────────
CAL_API_KEY=your_cal_api_key
CAL_EVENT_TYPE_ID=1234567

# ── Telegram Notifications ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ── WhatsApp (Meta Cloud API) ────────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_TOKEN=your_meta_bearer_token
ADMIN_WHATSAPP_NUMBER=919999999999

# ── Vobiz SIP Trunk ──────────────────────────────────────────────────────────
VOBIZ_AUTH_ID=your_vobiz_auth_id
VOBIZ_AUTH_TOKEN=your_vobiz_auth_token
VOBIZ_SIP_DOMAIN=your_sip_domain.sip.vobiz.ai
VOBIZ_USERNAME=your_username
VOBIZ_PASSWORD=your_password
VOBIZ_OUTBOUND_NUMBER=+91XXXXXXXXXX

# ── Call Transfer ─────────────────────────────────────────────────────────────
DEFAULT_TRANSFER_NUMBER=+91XXXXXXXXXX
