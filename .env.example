# ══════════════════════════════════════════════════════════════════════════════
# .env.example — Copy to .env and fill in your values
# ══════════════════════════════════════════════════════════════════════════════

# ── LiveKit Cloud ───────────────────────────────────────────────────────────
# Get from: https://cloud.livekit.io/ → your project → Settings
LIVEKIT_URL=wss://your-livekit-url
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# ── OpenAI (LLM) ────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key

# ── Sarvam AI (STT + TTS) ───────────────────────────────────────────────────
# Get from: https://app.sarvam.ai/
SARVAM_API_KEY=your_sarvam_api_key

# ── Cal.com (Booking) ───────────────────────────────────────────────────────
# Get from: https://app.cal.com/settings/developer/api-keys
CAL_API_KEY=your_cal_api_key
CAL_EVENT_TYPE_ID=1234567

# ── Supabase (Database) ─────────────────────────────────────────────────────
# Get from: https://app.supabase.com/ → your project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# ── Supabase S3 (Call Recordings) ───────────────────────────────────────────
# Get from: Supabase Dashboard → Storage → Settings → S3 Access → Generate key
# Bucket: create a private bucket named 'call-recordings' in Storage
SUPABASE_S3_ACCESS_KEY=your_s3_access_key
SUPABASE_S3_SECRET_KEY=your_s3_secret_key
SUPABASE_S3_ENDPOINT=https://your-project.storage.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=ap-northeast-1

# ── Telegram Notifications ──────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram, then get your Chat ID
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ── SIP / VoBiz (optional) ──────────────────────────────────────────────────
VOBIZ_SIP_DOMAIN=your_sip_domain.sip.vobiz.ai
VOBIZ_USERNAME=your_username
VOBIZ_PASSWORD=your_password
VOBIZ_OUTBOUND_NUMBER=+91XXXXXXXXXX

# ── Call Transfer ────────────────────────────────────────────────────────────
# Phone number to transfer calls to (human agent fallback)
DEFAULT_TRANSFER_NUMBER=+91XXXXXXXXXX
